# OSS Configuration
# Copy this file to .env and fill in your values

# OSS Access Credentials
OSS_ACCESS_KEY_ID=your-access-key-id-here
OSS_ACCESS_KEY_SECRET=your-access-key-secret-here

# OSS Bucket Configuration
OSS_BUCKET_NAME=your-bucket-name
OSS_REGION=cn-hangzhou

# Default upload directory prefix (with trailing slash if needed)
# Example: "uploads/" will upload files to "uploads/filename.ext"
# Set to empty string "" to upload to bucket root
OSS_UPLOAD_PREFIX=uploads/

# Default expiration time for presigned URLs (in hours)
OSS_EXPIRES_HOURS=1
